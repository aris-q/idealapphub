rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public site content: anyone can read, only the logged-in admin can write.
    match /news/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /products/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Everything else stays locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
