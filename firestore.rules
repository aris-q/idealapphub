rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin allowlist — keep in sync with lib/admins.js.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in ['idealapphub@gmail.com'];
    }

    // Public site content: anyone can read, only admins can write.
    match /news/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /products/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // Everything else stays locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
